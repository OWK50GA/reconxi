NODE_ENV=development

PORT=3001
HOST=localhost
CLIENT_URL=
ALLOWED_REDIRECT_ORIGINS=

CORS_ORIGIN=*
SWAGGER_ENABLED=true

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=reconxi_user
DATABASE_PASSWORD=reconxi_password
DATABASE_NAME=reconxi_db
DATABASE_SYNC=false
DATABASE_LOGGING=false
DATABASE_SSL=false

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DEFAULT_TTL=900

# Generate with: openssl rand -hex 32
SECRET_MANAGER_ENCRYPTION_KEY=

# JWT (must be at least 32 characters each)
JWT_ACCESS_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d